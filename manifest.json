{
  "manifest_version": 3,
  "name": "网页笔记助手",
  "version": "1.0.0",
  "description": "一款便捷的网页阅读、内容总结与笔记记录工具，所有数据保存在本地浏览器中。",
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab",
    "unlimitedStorage"
  ],
  "action": {
    "default_title": "打开笔记侧边栏",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "打开笔记侧边栏"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
